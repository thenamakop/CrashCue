{
  "name": "crashcue-vscode",
  "displayName": "CrashCue",
  "description": "Audible feedback for failed terminal commands",
  "version": "0.2.3",
  "publisher": "thenamakop",
  "repository": {
    "type": "git",
    "url": "https://github.com/thenamakop/CrashCue.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/thenamakop/CrashCue#readme",
  "engines": {
    "vscode": "^1.80.0"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:crashcue.run",
    "onCommand:crashcue.test"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "vscode:prepublish": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
